# @firebase/rules-unit-testing declares a peer dependency on firebase@^10,
# while @genkit-ai/firebase (already a direct dependency) declares an
# optional peer on firebase@>=11.5.0 — both are satisfiable in practice
# (rules-unit-testing's actual runtime usage is compatible with firebase
# v12), but npm's strict peer resolution can't see that. legacy-peer-deps
# avoids CI failing on a peer-dependency false positive between two
# dev-only/optional-peer packages; see functions/package.json's
# dependency list for the actual versions in use.
legacy-peer-deps=true
