# Firebase Configuration
# Copy this file to .env and replace with your actual Firebase project values

# Get these values from Firebase Console > Project Settings > General > Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key-here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# Optional: Stripe Configuration (for payments)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Optional: Google Maps API Key (for location services)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# NOTE: There is intentionally no EXPO_PUBLIC_GEMINI_API_KEY here.
# The AI Symptom Checker's Gemini API key is a Cloud Functions secret
# (see functions/src/symptomChecker.ts), set via:
#   firebase functions:secrets:set GOOGLE_GENAI_API_KEY
# An EXPO_PUBLIC_* variable would ship inside the client app bundle, which
# is not a safe place for a billable third-party API key.

