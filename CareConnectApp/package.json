    "expo-av": "~16.0.7",
    "expo-barcode-scanner": "~13.0.1",
    "expo-camera": "~17.0.8",
    "expo-crypto": "~15.0.7",
    "expo-document-picker": "~14.0.7",
    "expo-haptics": "~15.0.7",
    "expo-image-picker": "~17.0.8",
